{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "mlir",
      "camelcase": "MLIR",
      "title": "MLIR",
      "scope": "source.mlir",
      "file-types": [
        "mlir"
      ],
      "injection-regex": "^mlir$",
      "class-name": "TreeSitterMlir"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for MLIR",
    "authors": [
      {
        "name": "Tendayi Kamucheka",
        "url": "https://tkamucheka.github.io"
      }
    ],
    "links": {
      "repository": "https://github.com/tkamucheka/tree-sitter-mlir",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": true
  }
}